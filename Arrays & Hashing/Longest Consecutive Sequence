## Hashset
class Solution(object):
    def longestConsecutive(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """

        if not nums: return 0
        hs=set(nums)
        count=0
        for num in hs:
            if num-1 not in hs:
                c=1
                ele=num
                while ele+1 in hs:
                    c+=1
                    ele=ele+1
                if c>count:
                    count=c
        return count




## SORTING APPROACH -- O(nlogn)
class Solution(object):
    def longestConsecutive(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        if len(nums)==0: return 0
        nums.sort()        
        count=1
        c=1
        for i in range(1,len(nums)):
            if nums[i]-1 == nums[i-1]:
                c+=1
            elif nums[i]==nums[i-1]:
                continue
            else:
                c=1
            
            if c>count:
                count=c
        return count



##Bruteforce -- TLE in LC -- O(n^3)
class Solution(object):
    def longestConsecutive(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        count=0
        for num in nums:
            c=1
            ele=num
            while ele+1 in nums:
                c+=1
                ele=ele+1
            if c>count:
                count=c
